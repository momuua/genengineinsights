---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, updatedDate, author = 'GEN Engine Insights', tags = [], image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={title + ' | GEN Engine Insights'} description={description} image={image}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map(tag => (
            <span class="inline-block bg-primary-100 text-primary-700 text-xs font-medium px-2.5 py-0.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-lg text-gray-600 mb-4">{description}</p>
      <div class="flex items-center text-sm text-gray-500 gap-4">
        <span>By {author}</span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <>
            <span>·</span>
            <span>Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </>
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-primary-600">
      <slot />
    </div>
  </article>
</BaseLayout>
