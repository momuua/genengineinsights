---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: any;
    updatedDate?: any;
    author?: string;
    tags?: string[];
    image?: string;
  };
}

const { frontmatter } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'GEN Engine Insights',
  tags = [],
  image,
} = frontmatter;

function formatDate(val: any): string {
  try {
    const d = val instanceof Date ? val : new Date(String(val).substring(0, 10));
    if (isNaN(d.getTime())) return String(val).substring(0, 10);
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return String(val).substring(0, 10);
  }
}

function toISOSafe(val: any): string {
  try {
    const d = val instanceof Date ? val : new Date(String(val).substring(0, 10));
    if (isNaN(d.getTime())) return String(val).substring(0, 10);
    return d.toISOString();
  } catch {
    return String(val).substring(0, 10);
  }
}

const formattedDate = formatDate(pubDate);
const isoDate = toISOSafe(pubDate);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": isoDate,
  "dateModified": updatedDate ? toISOSafe(updatedDate) : isoDate,
  "author": {
    "@type": "Organization",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": "GEN Engine Insights",
    "url": "https://www.genengineinsights.com"
  },
  "url": canonicalURL.toString(),
  "keywords": tags.join(', ')
};
---

<BaseLayout title={title + ' | GEN Engine Insights'} description={description} image={image}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map(tag => (
            <span class="inline-block bg-primary-100 text-primary-700 text-xs font-medium px-2.5 py-0.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-lg text-gray-600 mb-4">{description}</p>
      <div class="flex items-center text-sm text-gray-500 gap-4">
        <span>By {author}</span>
        <span>·</span>
        <time datetime={isoDate}>{formattedDate}</time>
        {updatedDate && (
          <span>· Updated {formatDate(updatedDate)}</span>
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-primary-600">
      <slot />
    </div>
  </article>
</BaseLayout>



























































































