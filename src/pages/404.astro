---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found | GEN Engine Insights" description="The page you're looking for doesn't exist.">
  <div class="max-w-4xl mx-auto px-4 py-32 text-center">
    <h1 class="text-8xl font-bold text-primary-200 mb-4">404</h1>
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Page Not Found</h2>
    <p class="text-gray-600 mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex gap-4 justify-center">
      <a href="/" class="bg-primary-600 hover:bg-primary-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
        Go Home
      </a>
      <a href="/blog" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors">
        Read Blog
      </a>
    </div>
  </div>
</BaseLayout>
