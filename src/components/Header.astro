---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary-700 hover:text-primary-900">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      <span>GEN Engine Insights</span>
    </a>
    
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a 
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath === link.href ? 'text-primary-600' : 'text-gray-700'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button 
      class="md:hidden p-2 text-gray-600 hover:text-gray-900"
      id="mobile-menu-btn"
      aria-label="Toggle mobile menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  
  <div class="md:hidden hidden" id="mobile-menu">
    <div class="px-4 py-3 border-t border-gray-100 space-y-1">
      {navLinks.map(link => (
        <a 
          href={link.href}
          class:list={[
            'block py-2 text-sm font-medium transition-colors hover:text-primary-600',
            currentPath === link.href ? 'text-primary-600' : 'text-gray-700'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
