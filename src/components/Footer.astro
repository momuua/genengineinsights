---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-lg text-gray-900 mb-3">GEN Engine Insights</h3>
        <p class="text-sm text-gray-600 leading-relaxed">
          Expert insights on optimizing your content for AI-powered search engines and generative AI discovery.
        </p>
      </div>
      
      <div>
        <h4 class="font-semibold text-gray-900 mb-3">Navigate</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="/" class="hover:text-primary-600 transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">Blog</a></li>
          <li><a href="/about" class="hover:text-primary-600 transition-colors">About</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="font-semibold text-gray-900 mb-3">Topics</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">GEO Strategy</a></li>
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">AI Search</a></li>
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">Content Optimization</a></li>
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">Zero-Click Answers</a></li>
        </ul>
      </div>
    </div>
    
    <div class="mt-10 pt-6 border-t border-gray-200 text-center text-sm text-gray-500">
      <p>&copy; {currentYear} GEN Engine Insights. All rights reserved.</p>
    </div>
  </div>
</footer>
